# Steel-dev API Configuration
# Set this to your steel-dev API endpoint
# For local development: http://localhost:3000
# For remote deployment: https://your-steel-dev-instance.com
STEEL_API_URL=http://localhost:3000

# Stateful Steel Sessions Configuration
# If running Steel locally, set STEEL_LOCAL=true and optionally STEEL_BASE_URL
STEEL_LOCAL=true
# Base URL for Steel Sessions API (cloud: https://api.steel.dev, local: http://localhost:3000)
STEEL_BASE_URL=http://localhost:3000
# Required for cloud mode (STEEL_LOCAL=false)
STEEL_API_KEY=your_steel_api_key
# Session timeout in milliseconds (default: 900000 = 15 minutes)
STEEL_SESSION_TIMEOUT_MS=900000
# Optional global wait after each action (seconds)
STEEL_GLOBAL_WAIT_SECONDS=0
# Auto-release idle sessions after this many milliseconds (0 disables)
STEEL_IDLE_TIMEOUT_MS=600000
